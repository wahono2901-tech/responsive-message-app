{
    "name": "responsive-message-app/smkn12",
    "description": "Aplikasi Responsive Message SMKN 12 Jakarta",
    "type": "project",
    "require": {
        "phpoffice/phpspreadsheet": "5.0",
        "mitoteam/jpgraph": "^10.5",
        "mpdf/mpdf": "^8.2",
        "phpmailer/phpmailer": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
